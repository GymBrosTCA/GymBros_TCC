<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check-ins — GymBros Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<div class="admin-wrapper">
    <%- include('../partials/admin-sidebar') %>
    <div class="admin-content">
        <%- include('../partials/admin-topbar') %>
        <main class="admin-main">
            <h1 class="admin-page-title">Check-ins</h1>
            <p class="admin-page-subtitle"><%= total %> registros | <strong class="text-gold"><%= checkinsHoje %></strong> check-ins hoje</p>

            <!-- Chart + Filtro -->
            <div class="admin-charts-grid" style="margin-bottom:20px">
                <div class="admin-card">
                    <div class="admin-card-header">
                        <span class="admin-card-title"><i class="fas fa-chart-bar text-gold"></i> Check-ins por Dia da Semana</span>
                    </div>
                    <div class="admin-card-body">
                        <div class="chart-wrap"><canvas id="chartCheckins"></canvas></div>
                    </div>
                </div>
                <div class="admin-card">
                    <div class="admin-card-header"><span class="admin-card-title">Filtrar</span></div>
                    <div class="admin-card-body">
                        <form method="GET" action="/admin/checkins">
                            <div class="admin-form-group">
                                <label>Academia</label>
                                <select name="academia" class="admin-input">
                                    <option value="">Todas</option>
                                    <% academias.forEach(a => { %>
                                    <option value="<%= a.id %>" <%= academia===a.id?'selected':'' %>><%= a.nome %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <button type="submit" class="btn btn-gold w-100" style="justify-content:center"><i class="fas fa-filter"></i> Filtrar</button>
                            <% if (academia) { %>
                            <a href="/admin/checkins" class="btn btn-outline w-100 mt-8" style="justify-content:center;margin-top:8px">Limpar</a>
                            <% } %>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Tabela -->
            <div class="admin-card">
                <div class="admin-card-body no-pad">
                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead><tr><th>Usuário</th><th>Academia</th><th>Data</th><th>Hora</th></tr></thead>
                            <tbody>
                            <% items.forEach(c => { %>
                            <tr>
                                <td class="fw-600"><%= c.userName %></td>
                                <td class="text-muted"><%= c.academiaNome %></td>
                                <td class="text-muted"><%= c.dataStr %></td>
                                <td><span class="badge badge-muted"><%= c.hora %></span></td>
                            </tr>
                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <% if (pages > 1) { %>
            <div class="admin-pagination">
                <% for (let i = 1; i <= pages; i++) { %>
                <a href="/admin/checkins?academia=<%= academia %>&page=<%= i %>" class="<%= i===currentPage?'active':'' %>"><%= i %></a>
                <% } %>
            </div>
            <% } %>
        </main>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="/js/admin.js"></script>
<script>
new Chart(document.getElementById('chartCheckins'), {
    type: 'bar',
    data: {
        labels: <%- diasSemana %>,
        datasets: [{ data: <%- heatmap %>, backgroundColor: 'rgba(201,139,29,0.7)', borderRadius: 6 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { color: '#2A2A2A' }, ticks: { color: '#9A9A9A' } }, y: { grid: { color: '#2A2A2A' }, ticks: { color: '#9A9A9A' }, beginAtZero: true } } }
});
</script>
</body>
</html>
