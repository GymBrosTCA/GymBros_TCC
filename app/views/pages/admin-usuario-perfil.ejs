<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.nome %> — GymBros Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<div class="admin-wrapper">
    <%- include('../partials/admin-sidebar') %>
    <div class="admin-content">
        <%- include('../partials/admin-topbar') %>
        <main class="admin-main">
            <div class="flex gap-10 mb-16">
                <a href="/admin/usuarios" class="btn btn-outline btn-sm"><i class="fas fa-arrow-left"></i> Usuários</a>
                <h1 class="admin-page-title" style="margin:0"><%= user.nome %></h1>
            </div>

            <div class="admin-profile-grid">
                <!-- Sidebar do perfil -->
                <div>
                    <div class="admin-profile-card">
                        <div class="avatar"><i class="fas fa-user"></i></div>
                        <h2><%= user.nome %></h2>
                        <div class="text-muted" style="font-size:.8rem"><%= user.email %></div>
                        <span class="badge badge-gold plan-badge"><%= user.plano || '—' %></span>
                        <span class="badge <%= user.status==='ativo'?'badge-success':'badge-muted' %> mt-4" style="display:inline-block"><%= user.status || 'ativo' %></span>

                        <ul class="admin-detail-list mt-8">
                            <li><span>CPF</span><span><%= user.cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4') %></span></li>
                            <li><span>CEP</span><span><%= user.cep || '—' %></span></li>
                            <li><span>Cadastro</span><span><%= user.createdAt.toLocaleDateString('pt-BR') %></span></li>
                            <li><span>Academia</span><span><%= (academias.find(a=>a.id===user.academiaId)||{}).nome || '—' %></span></li>
                        </ul>

                        <div style="display:flex;flex-direction:column;gap:8px;margin-top:16px">
                            <button class="btn btn-danger btn-sm" data-toggle-user="<%= user.id %>">
                                <i class="fas <%= user.status==='ativo'?'fa-ban':'fa-check' %>"></i>
                                <%= user.status==='ativo' ? 'Desativar conta' : 'Reativar conta' %>
                            </button>
                        </div>
                    </div>

                    <!-- IMC -->
                    <% if (user.imc) { %>
                    <div class="admin-card mt-8" style="margin-top:16px">
                        <div class="admin-card-header"><span class="admin-card-title"><i class="fas fa-weight text-gold"></i> Perfil IMC</span></div>
                        <div class="admin-card-body">
                            <ul class="admin-detail-list">
                                <li><span>Peso</span><span><%= user.imc.peso %> kg</span></li>
                                <li><span>Altura</span><span><%= user.imc.altura %> m</span></li>
                                <li><span>Objetivo</span><span><%= user.imc.objetivo %></span></li>
                                <li><span>Lesões</span><span><%= (user.imc.lesoes||[]).join(', ') || 'Nenhuma' %></span></li>
                            </ul>
                        </div>
                    </div>
                    <% } %>
                </div>

                <!-- Conteúdo principal -->
                <div>
                    <!-- Check-ins recentes -->
                    <div class="admin-card" style="margin-bottom:16px">
                        <div class="admin-card-header">
                            <span class="admin-card-title"><i class="fas fa-map-marker-check text-gold"></i> Check-ins Recentes</span>
                            <span class="badge badge-muted"><%= userCheckins.length %> registros</span>
                        </div>
                        <div class="admin-card-body no-pad">
                            <% if (!userCheckins.length) { %>
                            <div class="admin-empty"><i class="fas fa-map-marker-slash"></i>Nenhum check-in registrado</div>
                            <% } else { %>
                            <table class="admin-table">
                                <thead><tr><th>Academia</th><th>Data</th><th>Hora</th></tr></thead>
                                <tbody>
                                <% userCheckins.forEach(c => { %>
                                <tr>
                                    <td><%= c.academiaNome %></td>
                                    <td class="text-muted"><%= c.dataStr %></td>
                                    <td class="text-muted"><%= c.hora %></td>
                                </tr>
                                <% }) %>
                                </tbody>
                            </table>
                            <% } %>
                        </div>
                    </div>

                    <!-- Histórico financeiro -->
                    <div class="admin-card" style="margin-bottom:16px">
                        <div class="admin-card-header">
                            <span class="admin-card-title"><i class="fas fa-receipt text-gold"></i> Histórico Financeiro</span>
                        </div>
                        <div class="admin-card-body no-pad">
                            <% if (!userTransacoes.length) { %>
                            <div class="admin-empty"><i class="fas fa-receipt"></i>Sem transações</div>
                            <% } else { %>
                            <table class="admin-table">
                                <thead><tr><th>Plano</th><th>Valor</th><th>Data</th><th>Status</th></tr></thead>
                                <tbody>
                                <% userTransacoes.forEach(t => { %>
                                <tr>
                                    <td><%= t.planoNome %></td>
                                    <td class="fw-600">R$ <%= t.valor.toFixed(2) %></td>
                                    <td class="text-muted"><%= t.data.toLocaleDateString('pt-BR') %></td>
                                    <td>
                                        <span class="badge <%= t.status==='pago'?'badge-success':t.status==='pendente'?'badge-warning':'badge-error' %>"><%= t.status %></span>
                                    </td>
                                </tr>
                                <% }) %>
                                </tbody>
                            </table>
                            <% } %>
                        </div>
                    </div>

                    <!-- Tickets de suporte -->
                    <div class="admin-card">
                        <div class="admin-card-header">
                            <span class="admin-card-title"><i class="fas fa-headset text-gold"></i> Tickets de Suporte</span>
                        </div>
                        <div class="admin-card-body no-pad">
                            <% if (!userTickets.length) { %>
                            <div class="admin-empty"><i class="fas fa-check-circle"></i>Sem chamados</div>
                            <% } else { %>
                            <table class="admin-table">
                                <thead><tr><th>Assunto</th><th>Tipo</th><th>Abertura</th><th>Status</th><th></th></tr></thead>
                                <tbody>
                                <% userTickets.forEach(t => { %>
                                <tr>
                                    <td><%= t.assunto %></td>
                                    <td class="text-muted"><%= t.tipo %></td>
                                    <td class="text-muted"><%= t.createdAt.toLocaleDateString('pt-BR') %></td>
                                    <td><span class="badge <%= t.status==='resolvido'?'badge-success':t.status==='em_atendimento'?'badge-info':'badge-warning' %>"><%= t.status.replace('_',' ') %></span></td>
                                    <td><a href="/admin/suporte/<%= t.id %>" class="btn btn-outline btn-sm btn-icon"><i class="fas fa-eye"></i></a></td>
                                </tr>
                                <% }) %>
                                </tbody>
                            </table>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
<script src="/js/admin.js"></script>
</body>
</html>
