<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo') %>
<link rel="icon" type="image/x-icon" href="/images/favicon.ico">
<link rel="stylesheet" href="/css/header.css">
<link rel="stylesheet" href="/css/footer.css">
<link rel="stylesheet" href="/css/area-aluno.css">
</head>
<body>

<%- include('../partials/header') %>

<section class="aluno-dashboard">

    <!-- SIDEBAR -->
    <section class="aluno-sidebar">
        <section class="aluno-profile">
            <section class="avatar">
                <img src="/images/avatar.png" alt="Avatar do Aluno">
            </section>
            <h2><%= user.nome %></h2>
            <p data-translate="sidebar.role">Aluno GymBros</p>
        </section>
        <ul class="aluno-menu">
            <li><a href="/area-aluno" class="active" data-translate="sidebar.painel"><i class="fas fa-tachometer-alt"></i> Painel</a></li>
            <li><a href="/treinos" data-translate="sidebar.treinos"><i class="fas fa-dumbbell"></i> Meus Treinos</a></li>
            <li><a href="/evolucao" data-translate="sidebar.evolucao"><i class="fas fa-chart-line"></i> Evolução</a></li>
            <li><a href="/meu-plano" data-translate="sidebar.plano"><i class="fas fa-file-alt"></i> Meu Plano</a></li>
            <li><a href="/config" data-translate="sidebar.config"><i class="fas fa-cog"></i> Configurações</a></li>
            <li><a href="/ai/chat" data-translate="sidebar.ai"><i class="fas fa-robot"></i> Personal Trainer IA</a></li>
            <li><a href="/ai/avaliacao" data-translate="sidebar.avaliacao"><i class="fas fa-camera"></i> Avaliação Corporal</a></li>
            <li><a href="/imc-form" data-translate="sidebar.imc"><i class="fas fa-clipboard-list"></i> Meu Perfil IMC</a></li>
            <li><a href="/suporte"><i class="fas fa-headset"></i> Suporte</a></li>
        </ul>
    </section>

    <!-- CONTEÚDO PRINCIPAL -->
    <section class="aluno-main">

        <!-- TOPO DASHBOARD -->
        <section class="dashboard-top">
            <h1>Bem-vindo, <%= user.nome %>!</h1>
            <p>Acompanhe seu progresso, treinos e planos</p>
        </section>

        <!-- CARDS -->
        <section class="cards-container">
            <section class="card card-blue">
                <h3>Meus Treinos</h3>
                <span class="card-value">70%</span>
                <a href="/treinos" class="btn-card">Ver Treinos</a>
            </section>

            <section class="card card-orange">
                <h3>Evolução</h3>
                <canvas class="line-graph" width="200" height="120"></canvas>
                <a href="/evolucao" class="btn-card">Ver Evolução</a>
            </section>

            <section class="card card-green">
                <h3>Meu Plano</h3>
                <section class="progress-bar">
                    <section class="progress-fill" style="width: 80%;"></section>
                </section>
                <span class="card-value">80%</span>
                <a href="/meu-plano" class="btn-card">Ver Plano</a>
            </section>
        </section>

        <!-- ATIVIDADES RECENTES -->
        <section class="recent-activities">
            <h2>Atividades Recentes</h2>
            <ul>
                <li><i class="fas fa-dumbbell"></i> Treino de Peito <span>Ontem</span></li>
                <li><i class="fas fa-dumbbell"></i> Treino de Inferiores <span>2 dias atrás</span></li>
                <li><i class="fas fa-leaf"></i> Yoga leve <span>3 dias atrás</span></li>
            </ul>
        </section>

        <!-- BADGES & METAS -->
        <section class="goals-badges">
            <h2>Metas & Conquistas</h2>
            <section class="goal">
                <p>Meta semanal: 5 treinos</p>
                <section class="progress-bar">
                    <section class="progress-fill" style="width: 60%;"></section>
                </section>
            </section>
            <section class="badges">
                <span class="badge">🏆 1ª Meta Semana</span>
                <span class="badge">💪 Consistência 3 dias</span>
            </section>
        </section>

    </section>

</section>

<%- include('../partials/footer') %>
<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
<script src="/js/area-aluno.js"></script>
<script src="/js/translate.js"></script>
</body>
</html>
