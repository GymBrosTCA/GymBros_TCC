<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('../partials/seo') %>
<link rel="icon" type="image/x-icon" href="/images/favicon.ico">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="/css/header.css">
<link rel="stylesheet" href="/css/footer.css">
<link rel="stylesheet" href="/css/area-aluno.css">
<style>
/* ── Suporte page ─────────────────────────── */
.ticket-list { display: flex; flex-direction: column; gap: 10px; }
.ticket-item {
    background: var(--card-bg, #1E1E1E);
    border: 1px solid var(--card-border, #2A2A2A);
    border-radius: 10px;
    padding: 14px 18px;
    cursor: pointer;
    transition: border-color .2s;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}
.ticket-item:hover { border-color: #C98B1D; }
.ticket-title { font-weight: 600; margin-bottom: 3px; }
.ticket-meta  { font-size: .78rem; color: #9A9A9A; }
.ticket-status {
    padding: 3px 12px; border-radius: 20px; font-size: .72rem; font-weight: 600;
    white-space: nowrap; flex-shrink: 0;
}
.ticket-status.aberto       { background: rgba(245,158,11,.15); color: #F59E0B; }
.ticket-status.em_atendimento { background: rgba(59,130,246,.15); color: #3B82F6; }
.ticket-status.resolvido    { background: rgba(34,197,94,.15); color: #22C55E; }

/* Chat */
.suporte-chat { display: none; flex-direction: column; height: 400px; background: #171717; border: 1px solid #2A2A2A; border-radius: 10px; }
.suporte-chat.open { display: flex; }
.suporte-chat-msgs { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 8px; }
.bubble { max-width: 78%; padding: 10px 14px; border-radius: 14px; font-size: .85rem; line-height: 1.45; }
.bubble-body { word-break: break-word; }
.bubble.usuario { background: #252525; border: 1px solid #2A2A2A; align-self: flex-end; border-bottom-right-radius: 3px; }
.bubble.admin   { background: rgba(201,139,29,.12); border: 1px solid rgba(201,139,29,.25); align-self: flex-start; border-bottom-left-radius: 3px; }
.bubble-meta    { font-size: .68rem; color: #777; margin-top: 4px; }
.bubble-in      { animation: bubbleIn .22s ease; }
@keyframes bubbleIn { from { opacity:0; transform:translateY(6px) scale(.97); } to { opacity:1; transform:none; } }
.chat-input-row { border-top: 1px solid #2A2A2A; padding: 10px; display: flex; gap: 8px; }
.chat-input-row textarea { flex: 1; background: #252525; border: 1px solid #333; color: #F0F0F0; padding: 8px 11px; border-radius: 7px; font-size: .85rem; font-family: inherit; resize: none; height: 56px; }
.chat-input-row textarea:focus { outline: none; border-color: #C98B1D; }
.btn-send { background: #C98B1D; color: #000; border: none; border-radius: 7px; padding: 0 16px; font-weight: 600; cursor: pointer; }
.btn-send:hover { background: #E0A835; }

body.light-mode .ticket-item { background: #E8E6E3; border-color: #DEDAD6; }
body.light-mode .suporte-chat { background: #E8E6E3; border-color: #DEDAD6; }
body.light-mode .bubble.usuario { background: #DEDAD6; }
</style>
</head>
<body>

<%- include('../partials/header') %>

<section class="aluno-dashboard">

    <!-- SIDEBAR -->
    <section class="aluno-sidebar">
        <section class="aluno-profile">
            <section class="avatar">
                <img src="/images/avatar.png" alt="Avatar do Aluno">
            </section>
            <h2><%= user.nome %></h2>
            <p data-translate="sidebar.role">Aluno GymBros</p>
        </section>
        <ul class="aluno-menu">
            <li><a href="/area-aluno" data-translate="sidebar.painel"><i class="fas fa-tachometer-alt"></i> Painel</a></li>
            <li><a href="/treinos" data-translate="sidebar.treinos"><i class="fas fa-dumbbell"></i> Meus Treinos</a></li>
            <li><a href="/evolucao" data-translate="sidebar.evolucao"><i class="fas fa-chart-line"></i> Evolução</a></li>
            <li><a href="/meu-plano" data-translate="sidebar.plano"><i class="fas fa-file-alt"></i> Meu Plano</a></li>
            <li><a href="/config" data-translate="sidebar.config"><i class="fas fa-cog"></i> Configurações</a></li>
            <li><a href="/ai/chat" data-translate="sidebar.ai"><i class="fas fa-robot"></i> Personal Trainer IA</a></li>
            <li><a href="/ai/avaliacao" data-translate="sidebar.avaliacao"><i class="fas fa-camera"></i> Avaliação Corporal</a></li>
            <li><a href="/imc-form" data-translate="sidebar.imc"><i class="fas fa-clipboard-list"></i> Meu Perfil IMC</a></li>
            <li><a href="/suporte" class="active"><i class="fas fa-headset"></i> Suporte</a></li>
        </ul>
    </section>

    <!-- CONTEÚDO PRINCIPAL -->
    <section class="aluno-main">
        <section class="dashboard-top">
            <h1><i class="fas fa-headset"></i> Central de Suporte</h1>
            <p>Abra chamados e acompanhe o status do seu atendimento</p>
        </section>

        <!-- Abrir chamado -->
        <section class="card" style="margin-bottom:20px">
            <h3 style="margin-bottom:14px"><i class="fas fa-plus-circle"></i> Abrir Novo Chamado</h3>
            <form id="form-ticket">
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
                    <div>
                        <label style="display:block;font-size:.82rem;margin-bottom:5px;opacity:.7">Assunto *</label>
                        <input type="text" id="ticket-assunto" placeholder="Descreva brevemente o problema" required
                            style="width:100%;background:rgba(255,255,255,.05);border:1px solid #333;color:inherit;padding:9px 12px;border-radius:7px;font-size:.875rem">
                    </div>
                    <div>
                        <label style="display:block;font-size:.82rem;margin-bottom:5px;opacity:.7">Tipo</label>
                        <select id="ticket-tipo"
                            style="width:100%;background:rgba(255,255,255,.05);border:1px solid #333;color:inherit;padding:9px 12px;border-radius:7px;font-size:.875rem">
                            <option value="Problema no app">Problema no app</option>
                            <option value="Dúvida sobre plano">Dúvida sobre plano</option>
                            <option value="Problema na academia">Problema na academia</option>
                            <option value="Outro">Outro</option>
                        </select>
                    </div>
                </div>
                <div style="margin-bottom:12px">
                    <label style="display:block;font-size:.82rem;margin-bottom:5px;opacity:.7">Descrição *</label>
                    <textarea id="ticket-descricao" rows="3" placeholder="Descreva detalhadamente o que aconteceu..." required
                        style="width:100%;background:rgba(255,255,255,.05);border:1px solid #333;color:inherit;padding:9px 12px;border-radius:7px;font-size:.875rem;font-family:inherit;resize:vertical"></textarea>
                </div>
                <button type="submit" class="btn-card" style="max-width:200px">
                    <i class="fas fa-paper-plane"></i> Enviar Chamado
                </button>
            </form>
        </section>

        <!-- Lista de tickets -->
        <section class="card">
            <h3 style="margin-bottom:14px"><i class="fas fa-list"></i> Meus Chamados</h3>
            <div id="tickets-list">
                <p style="opacity:.5;font-size:.875rem;text-align:center;padding:20px">Carregando chamados...</p>
            </div>
        </section>

        <!-- Chat de um ticket -->
        <section id="suporte-chat-section" style="display:none;margin-top:20px">
            <div class="card">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
                    <h3 id="chat-ticket-title" style="margin:0"><i class="fas fa-comments"></i> Chat do Chamado</h3>
                    <button onclick="closeChat()" style="background:none;border:none;color:inherit;cursor:pointer;opacity:.6;font-size:1.1rem">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="suporte-chat open" id="suporte-chat">
                    <div class="suporte-chat-msgs" id="chat-msgs"></div>
                    <div class="chat-input-row" id="chat-input-row">
                        <textarea id="chat-texto" placeholder="Digite sua mensagem..."></textarea>
                        <button class="btn-send" id="chat-send"><i class="fas fa-paper-plane"></i></button>
                    </div>
                </div>
            </div>
        </section>
    </section>
</section>

<%- include('../partials/footer') %>
<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
<script src="/js/translate.js"></script>
<script>
let currentTicketId = null;
let _sse = null;

// ── Carregar tickets do usuário ───────────────────────────
async function loadTickets() {
    try {
        const res = await fetch('/api/suporte/tickets');
        const lista = await res.json();
        const el = document.getElementById('tickets-list');
        if (!lista.length) {
            el.innerHTML = '<p style="opacity:.5;font-size:.875rem;text-align:center;padding:20px">Nenhum chamado aberto ainda.</p>';
            return;
        }
        el.innerHTML = '<div class="ticket-list">' + lista.map(t => `
            <div class="ticket-item" onclick="openChat('${t.id}', '${escHtml(t.assunto)}', '${t.status}')">
                <div>
                    <div class="ticket-title">${escHtml(t.assunto)}</div>
                    <div class="ticket-meta">#${t.id} • ${t.tipo} • ${new Date(t.createdAt).toLocaleDateString('pt-BR')}</div>
                </div>
                <span class="ticket-status ${t.status}">${t.status.replace('_',' ')}</span>
            </div>
        `).join('') + '</div>';
    } catch(e) { console.error(e); }
}

// ── Abrir chamado ─────────────────────────────────────────
document.getElementById('form-ticket').addEventListener('submit', async e => {
    e.preventDefault();
    const assunto   = document.getElementById('ticket-assunto').value.trim();
    const tipo      = document.getElementById('ticket-tipo').value;
    const descricao = document.getElementById('ticket-descricao').value.trim();
    if (!assunto || !descricao) return;
    try {
        const res  = await fetch('/api/suporte/tickets', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ assunto, tipo, descricao }) });
        const data = await res.json();
        if (!res.ok) throw new Error(data.erro);
        document.getElementById('ticket-assunto').value = '';
        document.getElementById('ticket-descricao').value = '';
        await loadTickets();
        openChat(data.ticket.id, data.ticket.assunto, 'aberto');
    } catch(err) { alert('Erro: ' + err.message); }
});

// ── Abrir chat de um ticket ───────────────────────────────
async function openChat(id, assunto, status) {
    currentTicketId = id;
    document.getElementById('suporte-chat-section').style.display = 'block';
    document.getElementById('chat-ticket-title').textContent = '💬 ' + assunto;
    const inputRow = document.getElementById('chat-input-row');
    inputRow.style.display = status === 'resolvido' ? 'none' : 'flex';
    await loadMessages();
    document.getElementById('suporte-chat-section').scrollIntoView({ behavior: 'smooth' });
    // SSE para mensagens em tempo real
    if (_sse) { _sse.close(); _sse = null; }
    if (status !== 'resolvido') {
        _sse = new EventSource('/api/suporte/tickets/' + id + '/stream');
        _sse.addEventListener('new_message', function(e) {
            const msg = JSON.parse(e.data);
            if (msg.remetente === 'admin') {
                // Mostra bolha com animação
                appendBubble(msg);
                scrollMsgs();
            }
        });
        _sse.addEventListener('status_change', function(e) {
            const d = JSON.parse(e.data);
            if (d.status === 'resolvido') {
                document.getElementById('chat-input-row').style.display = 'none';
            }
        });
    }
}

function closeChat() {
    if (_sse) { _sse.close(); _sse = null; }
    currentTicketId = null;
    document.getElementById('suporte-chat-section').style.display = 'none';
}

async function loadMessages() {
    if (!currentTicketId) return;
    try {
        const res  = await fetch('/api/suporte/tickets/' + currentTicketId);
        const data = await res.json();
        const el   = document.getElementById('chat-msgs');
        el.innerHTML = data.mensagens.map(m => bubbleHtml(m)).join('');
        scrollMsgs();
    } catch(e) {}
}

function bubbleHtml(m) {
    const time = new Date(m.criadaEm).toLocaleTimeString('pt-BR', { hour:'2-digit', minute:'2-digit' });
    const sender = m.remetente === 'admin' ? 'Suporte GymBros' : 'Você';
    return `<div class="bubble ${m.remetente} bubble-in"><div class="bubble-body">${escHtml(m.texto)}</div><div class="bubble-meta">${sender} · ${time}</div></div>`;
}

function appendBubble(m) {
    const el = document.getElementById('chat-msgs');
    const div = document.createElement('div');
    div.innerHTML = bubbleHtml(m);
    el.appendChild(div.firstChild);
}

function scrollMsgs() {
    const el = document.getElementById('chat-msgs');
    if (el) el.scrollTop = el.scrollHeight;
}

// ── Enviar mensagem ───────────────────────────────────────
document.getElementById('chat-send').addEventListener('click', sendMsg);
document.getElementById('chat-texto').addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); }
});

async function sendMsg() {
    const ta    = document.getElementById('chat-texto');
    const texto = ta.value.trim();
    if (!texto || !currentTicketId) return;
    try {
        const res = await fetch('/api/suporte/tickets/' + currentTicketId + '/mensagem', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ texto }) });
        const msg = await res.json();
        ta.value = '';
        appendBubble(msg);
        scrollMsgs();
    } catch(e) {}
}

function escHtml(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// Carrega tickets ao iniciar
loadTickets();
</script>
</body>
</html>
