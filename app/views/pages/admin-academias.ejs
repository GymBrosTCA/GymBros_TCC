<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academias — GymBros Admin</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<div class="admin-wrapper">
    <%- include('../partials/admin-sidebar') %>
    <div class="admin-content">
        <%- include('../partials/admin-topbar') %>
        <main class="admin-main">
            <div class="flex-between mb-16">
                <div>
                    <h1 class="admin-page-title">Academias</h1>
                    <p class="admin-page-subtitle"><%= academias.length %> academias cadastradas</p>
                </div>
                <button class="btn btn-gold" data-modal-open="modal-academia">
                    <i class="fas fa-plus"></i> Nova Academia
                </button>
            </div>

            <div class="admin-card">
                <div class="admin-card-body no-pad">
                    <div class="admin-table-wrap">
                        <table class="admin-table">
                            <thead>
                                <tr><th>Nome</th><th>CNPJ</th><th>Cidade</th><th>Responsável</th><th>Alunos</th><th>Status</th><th>Ações</th></tr>
                            </thead>
                            <tbody>
                            <% academias.forEach(a => { %>
                            <tr>
                                <td class="fw-600"><%= a.nome %></td>
                                <td class="text-muted"><%= a.cnpj %></td>
                                <td class="text-muted"><%= a.cidade %></td>
                                <td class="text-muted"><%= a.responsavel %></td>
                                <td><span class="badge badge-muted"><%= a.totalAlunos %></span></td>
                                <td><span class="badge <%= a.status==='ativa'?'badge-success':'badge-muted' %>"><%= a.status %></span></td>
                                <td>
                                    <div class="flex gap-10">
                                        <button class="btn btn-danger btn-sm btn-icon" data-toggle-academia="<%= a.id %>" title="<%= a.status==='ativa'?'Desativar':'Ativar' %>">
                                            <i class="fas <%= a.status==='ativa'?'fa-ban':'fa-check' %>"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Nova Academia -->
<div class="admin-modal-backdrop" id="modal-academia">
    <div class="admin-modal">
        <div class="admin-modal-header">
            <span class="admin-modal-title"><i class="fas fa-dumbbell text-gold"></i> Nova Academia</span>
            <button class="admin-modal-close" data-modal-close="modal-academia"><i class="fas fa-times"></i></button>
        </div>
        <form id="form-academia">
            <div class="admin-2col">
                <div class="admin-form-group">
                    <label>Nome *</label>
                    <input type="text" name="nome" class="admin-input" required placeholder="Smart Fit Centro">
                </div>
                <div class="admin-form-group">
                    <label>CNPJ *</label>
                    <input type="text" name="cnpj" class="admin-input" required placeholder="00.000.000/0001-00">
                </div>
            </div>
            <div class="admin-form-group">
                <label>Endereço</label>
                <input type="text" name="endereco" class="admin-input" placeholder="Rua das Flores, 123">
            </div>
            <div class="admin-2col">
                <div class="admin-form-group">
                    <label>Cidade</label>
                    <input type="text" name="cidade" class="admin-input" placeholder="São Paulo">
                </div>
                <div class="admin-form-group">
                    <label>CEP</label>
                    <input type="text" name="cep" class="admin-input" placeholder="00000-000">
                </div>
            </div>
            <div class="admin-2col">
                <div class="admin-form-group">
                    <label>Responsável</label>
                    <input type="text" name="responsavel" class="admin-input" placeholder="Nome do responsável">
                </div>
                <div class="admin-form-group">
                    <label>Telefone</label>
                    <input type="text" name="telefone" class="admin-input" placeholder="(11) 0000-0000">
                </div>
            </div>
            <div class="admin-modal-footer">
                <button type="button" class="btn btn-outline" data-modal-close="modal-academia">Cancelar</button>
                <button type="submit" class="btn btn-gold"><i class="fas fa-save"></i> Salvar Academia</button>
            </div>
        </form>
    </div>
</div>

<script src="/js/admin.js"></script>
</body>
</html>
