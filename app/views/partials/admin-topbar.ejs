<header class="admin-topbar">
    <section class="flex gap-10">
        <button id="admin-sidebar-toggle" class="btn btn-outline btn-icon" style="display:none" title="Menu">
            <i class="fas fa-bars"></i>
        </button>
        <span class="admin-topbar-title"><%= title %></span>
    </section>
    <section class="admin-topbar-right">
        <!-- Notification Bell -->
        <section class="admin-notif-wrap" id="notif-wrap">
            <button class="admin-notif-btn" id="notif-btn" title="Notificações">
                <i class="fas fa-bell"></i>
                <span class="admin-notif-badge" id="notif-badge" style="display:none">0</span>
            </button>
            <section class="admin-notif-panel" id="notif-panel">
                <section class="admin-notif-header">
                    <span>Atividade em tempo real</span>
                    <button onclick="clearNotifs()" class="admin-notif-clear">Limpar</button>
                </section>
                <section class="admin-notif-list" id="notif-list">
                    <section class="admin-notif-empty">Nenhuma atividade ainda</section>
                </section>
            </section>
        </section>

        <!-- Online users indicator -->
        <section class="admin-online-indicator" id="online-indicator" title="Usuários online agora">
            <span class="online-dot"></span>
            <span id="online-count">0</span> online
        </section>

        <span class="admin-topbar-admin">
            <strong><%= admin.email %></strong>
        </span>
        <a href="/admin/logout" class="btn admin-btn-logout">
            <i class="fas fa-sign-out-alt"></i> Sair
        </a>
    </section>
</header>
<script>
if (window.innerWidth <= 768) {
    document.getElementById('admin-sidebar-toggle').style.display = 'flex';
}
// Notification panel toggle
document.getElementById('notif-btn').addEventListener('click', function(e) {
    e.stopPropagation();
    document.getElementById('notif-panel').classList.toggle('open');
});
document.addEventListener('click', function(e) {
    if (!document.getElementById('notif-wrap').contains(e.target)) {
        document.getElementById('notif-panel').classList.remove('open');
    }
});
</script>